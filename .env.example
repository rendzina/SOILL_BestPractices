# SOILL Catalogue of Best Practices (T4.4) — environment configuration
# Copy to .env and set your local values. Do not commit .env to Git.

# -----------------------------------------------------------------------------
# MongoDB — Docker (mongodb_docker/docker-compose.yml)
# -----------------------------------------------------------------------------
MONGO_IMAGE=mongo:7
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_CONTAINER_NAME=local-mongo-dev
MONGO_VOLUME_NAME=local_mongo_data

# -----------------------------------------------------------------------------
# MongoDB — application connection (Python scripts)
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB=SOILL_catalogue
MONGO_COLLECTION=webscrape

# RAG chunk storage and chat logs (same database)
MONGODB_CHUNKS_COLLECTION=chunks
MONGODB_CONVERSATIONS_COLLECTION=soill_conversations

# -----------------------------------------------------------------------------
# Crawling settings (SOILL_scrape.py)
# -----------------------------------------------------------------------------
MIN_DELAY=2
REQUEST_TIMEOUT=15
MAX_PAGES_PER_SITE=0

# -----------------------------------------------------------------------------
# Chatbot — paths and Mistral API (build_faiss_index.py, app.py)
# -----------------------------------------------------------------------------
DATA_DIR=data

MISTRAL_API_KEY=
MISTRAL_EMBED_MODEL=mistral-embed
# If you see 429 "capacity exceeded", try open-mistral-nemo or mistral-medium-latest
MISTRAL_CHAT_MODEL=mistral-small-latest
# Optional second model tried after rate-limit retries on the primary model
MISTRAL_CHAT_MODEL_FALLBACK=open-mistral-nemo
MISTRAL_CHAT_RETRY_COUNT=2
MISTRAL_CHAT_RETRY_DELAY=2

RAG_TOP_K=8
RAG_MMR_ENABLED=true
RAG_MMR_LAMBDA=0.58
RAG_MMR_FETCH_MULT=3
RAG_MMR_FETCH_CAP=40

LOG_CONVERSATIONS=true

CHUNK_SIZE_WORDS=500
CHUNK_OVERLAP_WORDS=100
EMBED_BATCH_SIZE=32
