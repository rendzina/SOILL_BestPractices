# =============================================================================
# SOILL Catalogue of Best Practices (T4.4) — environment configuration
# =============================================================================
#
# Copy this file to .env and edit values for your machine:
#   cp .env.example .env
#
# Do not commit .env (it may contain secrets). Docker Compose and all Python
# scripts read from the repository root .env via config.py.
#
# Quick check: MONGO_HOST + MONGO_PORT must match the host/port in MONGO_URI.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. MongoDB — Docker (mongodb_docker/docker-compose.yml)
# -----------------------------------------------------------------------------
# Used when starting local MongoDB:
#   docker compose -f mongodb_docker/docker-compose.yml --env-file .env up -d

# Official MongoDB image tag
MONGO_IMAGE=mongo:7

# Bind address on your machine (127.0.0.1 = localhost only)
MONGO_HOST=127.0.0.1

# Port published to your host (change both here and in MONGO_URI if in use)
MONGO_PORT=27017

# Docker container name (choose a unique name per project on your machine)
MONGO_CONTAINER_NAME=local-mongo-dev

# Named Docker volume for persistent database files
MONGO_VOLUME_NAME=local_mongo_data


# -----------------------------------------------------------------------------
# 2. MongoDB — application connection (Python scripts)
# -----------------------------------------------------------------------------
# Connection string for pymongo — host and port must match MONGO_HOST / MONGO_PORT
MONGO_URI=mongodb://127.0.0.1:27017/

# Database name (same value as MONGO_INITDB_DATABASE in Docker)
MONGO_DB=SOILL_catalogue

# Collection for scraped HTML articles (SOILL_scrape.py)
MONGO_COLLECTION=webscrape


# -----------------------------------------------------------------------------
# 3. MongoDB — chatbot collections (same MONGO_DB)
# -----------------------------------------------------------------------------
# Embedded text chunks for RAG (build_faiss_index.py)
MONGODB_CHUNKS_COLLECTION=chunks

# Optional Q&A log from the chatbot (app.py, chat_cli.py)
MONGODB_CONVERSATIONS_COLLECTION=soill_conversations


# -----------------------------------------------------------------------------
# 4. Web scraping (SOILL_scrape.py)
# -----------------------------------------------------------------------------
# Minimum seconds between HTTP requests (politeness; jitter is added in code)
MIN_DELAY=2

# HTTP request timeout in seconds
REQUEST_TIMEOUT=15

# Maximum HTML pages per seed URL (0 = no limit)
MAX_PAGES_PER_SITE=0


# -----------------------------------------------------------------------------
# 5. Local data paths
# -----------------------------------------------------------------------------
# Root folder for generated data (FAISS index: data/faiss/ — gitignored)
DATA_DIR=data


# -----------------------------------------------------------------------------
# 6. Mistral API (build_faiss_index.py, app.py, chat_cli.py)
# -----------------------------------------------------------------------------
# Required for embeddings and chat. Obtain from https://console.mistral.ai/
MISTRAL_API_KEY=

# Model for embedding scraped text into vectors
MISTRAL_EMBED_MODEL=mistral-embed

# Primary model for answering questions
MISTRAL_CHAT_MODEL=mistral-small-latest

# Optional fallback if the primary model returns 429 capacity errors
# (leave empty to disable). Examples: open-mistral-nemo, mistral-medium-latest
MISTRAL_CHAT_MODEL_FALLBACK=open-mistral-nemo

# Retries per model on rate limit before trying the fallback
MISTRAL_CHAT_RETRY_COUNT=2

# Base delay in seconds between retries (multiplied by attempt number)
MISTRAL_CHAT_RETRY_DELAY=2


# -----------------------------------------------------------------------------
# 7. RAG retrieval (chatbot)
# -----------------------------------------------------------------------------
# Number of text chunks retrieved per question
RAG_TOP_K=8

# Maximal Marginal Relevance: diversify chunks (true/false)
RAG_MMR_ENABLED=true

# MMR balance: 1.0 = relevance only, 0.0 = diversity only
RAG_MMR_LAMBDA=0.58

# Initial FAISS fetch size multiplier (fetch up to RAG_TOP_K × this many)
RAG_MMR_FETCH_MULT=3

# Upper cap on candidates considered for MMR re-ranking
RAG_MMR_FETCH_CAP=40


# -----------------------------------------------------------------------------
# 8. Conversation logging and multi-turn chat
# -----------------------------------------------------------------------------
# Save each question/answer to MONGODB_CONVERSATIONS_COLLECTION (true/false)
LOG_CONVERSATIONS=true

# Also store client_ip and user_agent (GDPR: disclose in your privacy notice)
# Set false to log only thread_id and hashed visitor_fingerprint
LOG_CLIENT_METADATA=true

# Include recent Q&A turns in the prompt for follow-up questions (true/false)
CHAT_HISTORY_ENABLED=true

# How many prior question–answer pairs to send to the model (0 = disabled)
CHAT_HISTORY_TURNS=3

# Truncate long assistant replies in history to control token usage
CHAT_HISTORY_MAX_ANSWER_CHARS=1500


# -----------------------------------------------------------------------------
# 9. Index building — chunking and embeddings (build_faiss_index.py)
# -----------------------------------------------------------------------------
# Target chunk size in words when splitting articles
CHUNK_SIZE_WORDS=500

# Overlap between consecutive chunks in words
CHUNK_OVERLAP_WORDS=100

# Texts embedded per Mistral API batch request
EMBED_BATCH_SIZE=32
